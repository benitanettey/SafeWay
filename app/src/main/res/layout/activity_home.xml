<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_background"
    tools:context=".HomeActivity">

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/home_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/profile_avatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_profile"
                    android:contentDescription="@string/profile_avatar"
                    android:tint="@color/highlight_accent"
                    android:scaleType="centerInside"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/welcome_text"
                        android:textSize="12sp"
                        android:textColor="@color/neutral_text"/>

                    <TextView
                        android:id="@+id/user_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/user_name_default"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <ImageView
                    android:id="@+id/settings_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings"
                    android:contentDescription="@string/settings"
                    android:tint="@color/neutral_text"
                    android:scaleType="centerInside"/>

            </LinearLayout>

            <!-- Quick Actions Grid -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/quick_actions"
                android:textSize="10sp"
                android:textColor="@color/section_label"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="12dp">

                <!-- Emergency Alert Button -->
                <LinearLayout
                    android:id="@+id/btn_emergency"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_row="0"
                    android:layout_column="0"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/action_emergency_bg">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_alert"
                        android:contentDescription="@string/emergency_alert"
                        android:tint="@color/emergency_red"
                        android:scaleType="centerInside"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/emergency_alert"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/emergency_red"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

                <!-- Log Incident Button -->
                <LinearLayout
                    android:id="@+id/btn_log_incident"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_row="0"
                    android:layout_column="1"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/action_log_bg">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_log"
                        android:contentDescription="@string/log_incident"
                        android:tint="@color/highlight_accent"
                        android:scaleType="centerInside"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/log_incident"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/highlight_accent"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

                <!-- My Circle Button -->
                <LinearLayout
                    android:id="@+id/btn_my_circle"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_row="1"
                    android:layout_column="0"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/action_circle_bg">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_circle"
                        android:contentDescription="@string/my_circle"
                        android:tint="@color/neutral_text"
                        android:scaleType="centerInside"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/my_circle"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/neutral_text"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

                <!-- Records Button -->
                <LinearLayout
                    android:id="@+id/btn_records"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_row="1"
                    android:layout_column="1"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/action_records_bg">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_records"
                        android:contentDescription="@string/records"
                        android:tint="@color/neutral_text"
                        android:scaleType="centerInside"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/records"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/neutral_text"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

            </GridLayout>

            <!-- Shield Protection Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_shield"
                        android:contentDescription="@string/shield_protection"
                        android:tint="@color/primary_accent"
                        android:scaleType="centerInside"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/shield_protection"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_text"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/shield_status"
                            android:textSize="10sp"
                            android:textColor="@color/neutral_text"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/shield_toggle"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_toggle_on"
                        android:contentDescription="@string/shield_toggle"
                        android:tint="@color/highlight_accent"
                        android:scaleType="centerInside"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Support Hotlines Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/support_hotlines"
                android:textSize="10sp"
                android:textColor="@color/section_label"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp"/>

            <!-- Hotline Cards Container -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="20dp">

                <!-- Police Hotline -->
                <LinearLayout
                    android:id="@+id/btn_police_hotline"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_row="0"
                    android:layout_column="0"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/action_emergency_bg">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_alert"
                        android:contentDescription="@string/police"
                        android:tint="@color/emergency_red"
                        android:scaleType="centerInside"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/police"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/emergency_red"
                        android:layout_marginTop="6dp"/>

                </LinearLayout>

                <!-- Hospital Hotline -->
                <LinearLayout
                    android:id="@+id/btn_hospital_hotline"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_row="0"
                    android:layout_column="1"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/action_log_bg">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_log"
                        android:contentDescription="@string/hospital"
                        android:tint="@color/highlight_accent"
                        android:scaleType="centerInside"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hospital"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/highlight_accent"
                        android:layout_marginTop="6dp"/>

                </LinearLayout>

                <!-- Amnesty International -->
                <LinearLayout
                    android:id="@+id/btn_amnesty"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_row="1"
                    android:layout_column="0"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/action_circle_bg">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_circle"
                        android:contentDescription="@string/amnesty"
                        android:tint="@color/neutral_text"
                        android:scaleType="centerInside"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/amnesty"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/neutral_text"
                        android:layout_marginTop="6dp"/>

                </LinearLayout>

                <!-- Counselor Hotline -->
                <LinearLayout
                    android:id="@+id/btn_counselor"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_row="1"
                    android:layout_column="1"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/action_records_bg">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_records"
                        android:contentDescription="@string/counselor"
                        android:tint="@color/neutral_text"
                        android:scaleType="centerInside"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/counselor"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/neutral_text"
                        android:layout_marginTop="6dp"/>

                </LinearLayout>

            </GridLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/nav_bar_background"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                android:contentDescription="@string/home"
                android:tint="@color/highlight_accent"
                android:scaleType="centerInside"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/home"
                android:textColor="@color/highlight_accent"
                android:textSize="10sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_log"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_log"
                android:contentDescription="@string/log_incident"
                android:tint="@color/neutral_text"
                android:scaleType="centerInside"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/log_incident"
                android:textColor="@color/neutral_text"
                android:textSize="10sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_circle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_circle"
                android:contentDescription="@string/my_circle"
                android:tint="@color/neutral_muted"
                android:scaleType="centerInside"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/my_circle"
                android:textColor="@color/neutral_muted"
                android:textSize="10sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_records"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_records"
                android:contentDescription="@string/records"
                android:tint="@color/neutral_text"
                android:scaleType="centerInside"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/records"
                android:textColor="@color/neutral_text"
                android:textSize="10sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
