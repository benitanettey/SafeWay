<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_background">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="18dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WELCOME BACK"
                android:textSize="11sp"
                android:textColor="@color/neutral_muted"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thomas K."
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Profile Avatar -->
        <FrameLayout
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/avatar_background"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tv_avatar_initials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="TK"
                android:textSize="13sp"
                android:textColor="@color/highlight_accent"
                android:textStyle="bold"
                android:gravity="center" />

        </FrameLayout>

    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/secondary_background"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Quick Actions Section Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="QUICK ACTIONS"
                android:textSize="10sp"
                android:textColor="@color/section_label"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp" />

            <!-- Quick Actions Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="14dp"
                android:useDefaultMargins="false">

                <!-- Emergency Alert Action -->
                <FrameLayout
                    android:id="@+id/btn_emergency_alert"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/action_emergency_bg"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_alert"
                            android:tint="@color/emergency_red"
                            android:contentDescription="@string/emergency_alert" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/emergency_alert"
                            android:textSize="12sp"
                            android:textColor="@color/emergency_red"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Log Incident Action -->
                <FrameLayout
                    android:id="@+id/btn_log_incident"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/action_log_bg"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_log"
                            android:tint="@color/highlight_accent"
                            android:contentDescription="@string/log_incident" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/log_incident"
                            android:textSize="12sp"
                            android:textColor="@color/highlight_accent"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                </FrameLayout>

                <!-- My Circle Action -->
                <FrameLayout
                    android:id="@+id/btn_my_circle"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/action_circle_bg"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_circle"
                            android:tint="@color/neutral_text"
                            android:contentDescription="@string/my_circle" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/my_circle"
                            android:textSize="12sp"
                            android:textColor="@color/neutral_text"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Records Action -->
                <FrameLayout
                    android:id="@+id/btn_records"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/action_records_bg"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_records"
                            android:tint="@color/neutral_text"
                            android:contentDescription="@string/records" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/records"
                            android:textSize="12sp"
                            android:textColor="@color/neutral_text"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                </FrameLayout>

            </GridLayout>

            <!-- Your Safety Section Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="YOUR SAFETY"
                android:textSize="10sp"
                android:textColor="@color/section_label"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp" />

            <!-- Shield Protection Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/card_background"
                android:padding="14dp"
                android:orientation="vertical">

                <!-- Card Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/shield_protection"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/monitoring_active"
                            android:textSize="12sp"
                            android:textColor="@color/neutral_muted"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <!-- Toggle Switch -->
                    <ToggleButton
                        android:id="@+id/toggle_shield"
                        android:layout_width="42dp"
                        android:layout_height="24dp"
                        android:background="@drawable/toggle_background"
                        android:textOff=""
                        android:textOn=""
                        android:checked="true" />

                </LinearLayout>

                <!-- Description -->
                <TextView
                    android:id="@+id/tv_shield_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/shield_description"
                    android:textSize="12sp"
                    android:textColor="@color/neutral_text"
                    android:lineHeight="18sp"
                    android:layout_marginBottom="10dp" />

                <!-- Status Pills -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/shield_active"
                        android:layout_margin="3dp"
                        android:textSize="11sp"
                        app:chipBackgroundColor="@color/primary_accent"
                        app:chipStrokeColor="@color/primary_accent"
                        app:chipStrokeWidth="0dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_contacts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/shield_contacts"
                        android:layout_margin="3dp"
                        android:textSize="11sp"
                        app:chipBackgroundColor="@color/card_background"
                        app:chipStrokeColor="@color/border_dark"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_offline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/shield_offline_ready"
                        android:layout_margin="3dp"
                        android:textSize="11sp"
                        app:chipBackgroundColor="@color/card_background"
                        app:chipStrokeColor="@color/border_dark"
                        app:chipStrokeWidth="1dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom Navigation Bar -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/primary_background"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_navigation_menu"
        app:labelVisibilityMode="labeled" />

</androidx.constraintlayout.widget.ConstraintLayout>

