<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_background"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/record_details"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/record_detail_subtitle"
            android:textColor="@color/neutral_muted"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/et_detail_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/edit_text_bg"
            android:hint="@string/incident_type"
            android:inputType="text"
            android:padding="10dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/neutral_muted" />

        <EditText
            android:id="@+id/et_detail_description"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/edit_text_bg"
            android:gravity="top|start"
            android:hint="@string/describe_incident"
            android:inputType="textMultiLine"
            android:padding="10dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/neutral_muted" />

        <EditText
            android:id="@+id/et_detail_severity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/edit_text_bg"
            android:hint="@string/severity"
            android:inputType="text"
            android:padding="10dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/neutral_muted" />

        <EditText
            android:id="@+id/et_detail_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/edit_text_bg"
            android:hint="@string/location"
            android:inputType="text"
            android:padding="10dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/neutral_muted" />

        <EditText
            android:id="@+id/et_detail_who"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/edit_text_bg"
            android:hint="@string/who_optional"
            android:inputType="text"
            android:padding="10dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/neutral_muted" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_detail_photo"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:background="@drawable/button_secondary_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/preview_photo"
                android:textColor="@color/highlight_accent"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_detail_video"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/button_secondary_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/preview_video"
                android:textColor="@color/highlight_accent"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_detail_play"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:background="@drawable/button_secondary_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/play"
                android:textColor="@color/highlight_accent"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_detail_save"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/button_primary_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/save"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_detail_delete"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/button_secondary_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/delete"
                android:textColor="@color/emergency_red"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>


