<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_background">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back_records"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:contentDescription="@string/back"
            android:scaleType="centerInside" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/private_records_title"
            android:textSize="17sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:gravity="center" />

        <View
            android:layout_width="24dp"
            android:layout_height="24dp" />

    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/secondary_background"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="100dp">

            <!-- Alert Notification -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#0a1a2a"
                android:padding="12dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="10dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/pulse_dot"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Alert sent today 09:14 — 3 contacts notified, GPS logged"
                    android:textSize="12sp"
                    android:textColor="@color/highlight_accent" />

            </LinearLayout>

            <!-- Record 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="14dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Physical altercation"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mar 11 • 22:40"
                        android:textSize="11sp"
                        android:textColor="@color/neutral_muted" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Was struck on the shoulder at home. Denied it happened before to family members."
                    android:textSize="12sp"
                    android:textColor="@color/neutral_text"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:lineHeight="18sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="High"
                        android:layout_margin="3dp"
                        android:textSize="11sp"
                        app:chipBackgroundColor="#2a1418"
                        app:chipStrokeColor="#4a1a1a"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPS logged"
                        android:layout_margin="3dp"
                        android:textSize="11sp"
                        app:chipBackgroundColor="@color/card_background"
                        app:chipStrokeColor="@color/border_dark"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Voice note"
                        android:layout_margin="3dp"
                        android:textSize="11sp"
                        app:chipBackgroundColor="@color/primary_accent"
                        app:chipStrokeColor="@color/primary_accent"
                        app:chipStrokeWidth="0dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Record 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="14dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Verbal / emotional"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mar 8 • 18:22"
                        android:textSize="11sp"
                        android:textColor="@color/neutral_muted" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sustained verbal threats in front of children. Threatened to file false reports."
                    android:textSize="12sp"
                    android:textColor="@color/neutral_text"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:lineHeight="18sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Medium"
                        android:layout_margin="3dp"
                        android:textSize="11sp"
                        app:chipBackgroundColor="@color/card_background"
                        app:chipStrokeColor="@color/border_dark"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPS logged"
                        android:layout_margin="3dp"
                        android:textSize="11sp"
                        app:chipBackgroundColor="@color/card_background"
                        app:chipStrokeColor="@color/border_dark"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Timestamped"
                        android:layout_margin="3dp"
                        android:textSize="11sp"
                        app:chipBackgroundColor="@color/card_background"
                        app:chipStrokeColor="@color/border_dark"
                        app:chipStrokeWidth="1dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Record 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="14dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Financial control"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mar 2 • 10:05"
                        android:textSize="11sp"
                        android:textColor="@color/neutral_muted" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="All bank accounts restricted without consent for third consecutive week."
                    android:textSize="12sp"
                    android:textColor="@color/neutral_text"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:lineHeight="18sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Medium"
                        android:layout_margin="3dp"
                        android:textSize="11sp"
                        app:chipBackgroundColor="@color/card_background"
                        app:chipStrokeColor="@color/border_dark"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPS logged"
                        android:layout_margin="3dp"
                        android:textSize="11sp"
                        app:chipBackgroundColor="@color/card_background"
                        app:chipStrokeColor="@color/border_dark"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Voice note"
                        android:layout_margin="3dp"
                        android:textSize="11sp"
                        app:chipBackgroundColor="@color/primary_accent"
                        app:chipStrokeColor="@color/primary_accent"
                        app:chipStrokeWidth="0dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Export Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="14dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/export_for_legal"
                    android:textSize="10sp"
                    android:textColor="@color/section_label"
                    android:letterSpacing="0.15"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="All records include GPS coordinates, device timestamps, and hash verification for legal admissibility."
                    android:textSize="12sp"
                    android:textColor="@color/neutral_text"
                    android:layout_marginBottom="10dp"
                    android:lineHeight="18sp" />

                <Button
                    android:id="@+id/btn_export_report"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/button_secondary_bg"
                    android:text="@string/export_encrypted_report"
                    android:textColor="@color/highlight_accent"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

